model Subproject {
  id           String   @id @default(cuid())

  // Identification
  code                  String   @unique // Subproject ID
  title                 String

  // Domain Information
  ancestralDomain       String?  // name of CADT area
  cadtNumber            String?
  region                String?
  province              String?
  municipality          String?
  barangay              String?

  // Description
  description           String?  @db.Text

  // Physical Details
  targetLength          Decimal? @db.Decimal(12,2)
  unitOfMeasure         String?

  // Funding
  sourceOfFund          String?
  yearFunded            Int?
  totalBudget           Decimal? @db.Decimal(15,2)
  approvedBudget        Decimal? @db.Decimal(15,2)

  // Implementation
  implementingAgency    String?
  contractor            String?

  // GIS (for maps)
  latitude              Decimal? @db.Decimal(10,7)
  longitude             Decimal? @db.Decimal(10,7)

  // Timeline
  duration              Int?     // number of days
  startDate             DateTime?
  targetCompletionDate  DateTime?
  actualCompletionDate  DateTime?
  scopeOfWorks          String?  @db.Text

  // Status
  status                String? @default("Planned")

  progressReports     ProgressReport[]

  // System
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ProgressReport {
  id           String   @id @default(cuid())

  reportDate  DateTime? @db.Date
  targetProgress  Float?
  actualProgress  Float?

  subprojectId  String
  subproject   Subproject @relation(fields: [subprojectId], references: [id], onDelete: Cascade)

  @@unique([subprojectId, reportDate])
}
